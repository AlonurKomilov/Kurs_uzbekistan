# Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Database connection
POSTGRES_USER=kubot
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=kubot
DATABASE_URL=postgresql+asyncpg://kubot:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/kubot

# Test database (for pytest)
TEST_DATABASE_URL=postgresql+asyncpg://kubot:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/kubot_test

# SQL Debug logging (set to "true" for development, "false" for production)
SQL_DEBUG=false

# Telegram Web App Base URL (must be whitelisted domain)
TWA_BASE_URL=http://localhost:3000

# Monitoring and Error Tracking
SENTRY_DSN=
ENVIRONMENT=development

# API Rate Limiting (requests per minute)
API_RATE_LIMIT=60